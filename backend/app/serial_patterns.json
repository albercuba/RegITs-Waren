{
  "confidence_threshold": 70,
  "keywords": [
    "S/N",
    "S N",
    "SN",
    "SNR",
    "SER NO",
    "SERIAL",
    "SERIALNO",
    "SERIAL NO",
    "SERIAL NUMBER",
    "SERVICE TAG",
    "SER NR",
    "SER-NR",
    "SERIEN NR",
    "SERIEN-NR",
    "S-NUMMER",
    "S NUMMER",
    "SERIENNUMMER",
    "SERIEN NUMMER",
    "SERIEN-NUMMER"
  ],
  "candidate_patterns": [
    {
      "name": "keyword_serial",
      "regex": "\\b(?:S[ \\t]*/?[ \\t]*N|SN|SNR|SERIAL[ \\t]*(?:NO|NUMBER)?|SERIALNO|SERVICE[ \\t]+TAG|SERIEN[ \\t-]*(?:NR|NUMMER)|SER[ \\t-]*(?:NO|NR)|S[ \\t]*-?[ \\t]*NUMMER|SERIENNUMMER)[ \\t]*[:#-]?[ \\t]*([A-Z0-9][A-Z0-9 \\t-]{4,28})",
      "base_score": 100
    },
    {
      "name": "mixed_alphanumeric",
      "regex": "\\b([A-Z0-9-]{6,20})\\b",
      "base_score": 12
    },
    {
      "name": "letters_then_digits",
      "regex": "\\b([A-Z]{2,5}[0-9]{4,}[A-Z0-9-]*)\\b",
      "base_score": 18
    }
  ],
  "vendor_rules": {
    "Dell": [
      {
        "name": "dell_service_tag",
        "regex": "(?:SERVICE[ \\t]+TAG|ST)[ \\t]*[:#-]?[ \\t]*([A-Z0-9]{5,7})",
        "base_score": 55
      }
    ],
    "HP": [
      {
        "name": "hp_serial",
        "regex": "\\b(?:S[ \\t]*/?[ \\t]*N|SN|SNR|SERIAL[ \\t]*(?:NO|NUMBER)?|SERIALNO|SERIEN[ \\t-]*(?:NR|NUMMER)|SER[ \\t-]*(?:NO|NR)|SERIENNUMMER)[ \\t]*[:#-]?[ \\t]*([A-Z0-9][A-Z0-9 \\t-]{4,28})",
        "base_score": 100
      }
    ],
    "Lenovo": [
      {
        "name": "lenovo_serial",
        "regex": "(?:S[ \\t]*/[ \\t]*N|SN|SERIAL)[ \\t]*[:#-]?[ \\t]*([A-Z0-9]{6,20})",
        "base_score": 50
      },
      {
        "name": "lenovo_mtm_serial",
        "regex": "(?:MTM|TYPE)[ \\t]*[:#-]?[ \\t]*([A-Z0-9-]{4,})[ \\t]+(?:S[ \\t]*/[ \\t]*N|SN|SERIAL)[ \\t]*[:#-]?[ \\t]*([A-Z0-9]{6,20})",
        "base_score": 55
      }
    ]
  }
}
